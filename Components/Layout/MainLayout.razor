@using Microsoft.AspNetCore.Components.Web
@using Microsoft.JSInterop
@inherits LayoutComponentBase
@inject IJSRuntime JSRuntime

<div class="page">
    <div class="header">
        <NavMenu />
    </div>

    <main>
        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>

<script src="_framework/blazor.server.js"></script>

<!-- Use both script references -->
<script src="js-test.js"></script>
<script src="wsTest.js"></script>
<script src="blazor-monitor.js"></script>

<button @onclick="TestJavaScript"
    style="position: fixed; bottom: 10px; left: 10px; z-index: 9999; padding: 10px; background-color: blue; color: white;">
    Test JavaScript
</button>

@code {
    private async Task TestJavaScript()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("jsTest.sayHello");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"JavaScript error: {ex.Message}");
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                await JSRuntime.InvokeVoidAsync("console.log", "MainLayout first render complete");
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error: {ex.Message}");
            }
        }
    }
}